---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Quiniela XVs - Copa Mundial FIFA 2026' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Quiniela XVs - Copa Mundial FIFA 2026 - ¡El ganador se lleva todo!" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-gradient-to-br from-blue-50 to-green-50 min-h-screen">
    <slot />
  </body>
</html>
