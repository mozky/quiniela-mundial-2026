---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import TeamBadge from '../components/TeamBadge.astro';
import { getTeamsByTier } from '../data/teams';
import { assignments } from '../data/assignments';

const tier1Teams = getTeamsByTier(1);
const tier2Teams = getTeamsByTier(2);
const tier3Teams = getTeamsByTier(3);
const tier4Teams = getTeamsByTier(4);
---

<Layout>
  <main class="container mx-auto px-4 pb-16">
    <Header />

      <!-- Asignaciones -->
      <section class="bg-white rounded-lg shadow-lg p-8 border-2 border-purple-400">
        <h2 class="text-3xl font-bold text-purple-600 mb-6 text-center">
          Asignaciones de Equipos
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {assignments.map((assignment) => (
            <div class="bg-gradient-to-br from-purple-50 to-pink-50 rounded-lg p-4 shadow-md border-2 border-purple-200">
              <h3 class="text-xl font-bold text-purple-900 mb-4 text-center border-b-2 border-purple-300 pb-2">
                {assignment.friend}
              </h3>
              <div class="space-y-3">
                <div class="bg-blue-100 p-2 rounded">
                  <p class="text-xs text-blue-600 font-semibold mb-1">Tier 1: Favorito</p>
                  <TeamBadge teamId={assignment.tier1Team} />
                </div>
                <div class="bg-green-100 p-2 rounded">
                  <p class="text-xs text-green-600 font-semibold mb-1">Tier 2: Caballo Negro</p>
                  <TeamBadge teamId={assignment.tier2Team} />
                </div>
                <div class="bg-orange-100 p-2 rounded">
                  <p class="text-xs text-orange-600 font-semibold mb-1">Tier 3: Sorpresa</p>
                  <TeamBadge teamId={assignment.tier3Team} />
                </div>
              </div>
            </div>
          ))}
        </div>
        <p class="text-center text-gray-600 mt-6 italic">
          Cada participante tiene 1 equipo de cada tier
        </p>
      </section>

      <!-- Tier 4: No participan en la quiniela -->
      <section class="bg-gray-100 rounded-lg shadow p-8 border-2 border-gray-300 opacity-60">
        <h2 class="text-2xl font-bold text-gray-500 mb-6 text-center">
          Tier 4: No participan en la quiniela
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {tier4Teams.map((team) => (
            <div class="p-3 bg-gray-200 rounded-lg opacity-75">
              <TeamBadge teamId={team.id} />
            </div>
          ))}
        </div>
        <p class="text-center text-gray-500 mt-6 text-sm italic">
          Estos 9 equipos no están incluidos en la quiniela
        </p>
      </section>
    </div>

    <footer class="text-center mt-12 text-gray-600">
      <p class="text-sm">Copa Mundial 2026 • USA • Canadá • México</p>
    </footer>
  </main>
</Layout>
